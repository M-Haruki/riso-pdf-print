// メモ
// dockerfileだけでは、@fsあたりへのアクセスがうまくいかず、
// docker-composeを介すことで、正常に動作するようになった。

{
  "name": "Riso PDF Print DevContainer",
  "dockerComposeFile": "compose.yml",
  "service": "app",
  "workspaceFolder": "/workspace",
  "forwardPorts": [5173],
  "customizations": {
    "vscode": {
      "extensions": [
        "vue.volar",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode"
      ]
    }
  },
  "remoteUser": "node"
}
